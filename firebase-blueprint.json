{
  "entities": {
    "Document": {
      "title": "Document",
      "description": "A user-created Word document with multiple pages.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Owner of the document" },
        "title": { "type": "string", "description": "Title of the document" },
        "pages": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "HTML content for each page"
        },
        "headerContent": { "type": "string", "description": "HTML content for the header" },
        "footerContent": { "type": "string", "description": "HTML content for the footer" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "pages", "updatedAt", "createdAt"]
    }
  },
  "firestore": {
    "documents/{documentId}": {
      "schema": "Document",
      "description": "Store individual documents created by users."
    }
  }
}
